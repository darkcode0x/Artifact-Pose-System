gitignore
# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
/build/
/coverage/
generated_plugin_registrant.dart

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio artifacts
/android/app/debug
/android/app/profile
/android/app/release

# Secrets & Signing (QUAN TRỌNG)
**/key.properties
**/*.keystore
**/*.jks
**/*.pk8
**/*.pem
.env*

# Desktop ephemeral
/windows/flutter/ephemeral/
/linux/flutter/ephemeral/
/macos/Flutter/ephemeral/

# iOS/macOS related
**/Pods/
**/DerivedData/
*.moved-aside
*.xcworkspace
!default.xcworkspace