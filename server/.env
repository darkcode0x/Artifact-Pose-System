APP_NAME=IoT Artifact Server
APP_VERSION=1.0.0
APP_HOST=0.0.0.0
APP_PORT=8000
CORS_ALLOW_ORIGINS=*

DATA_DIR=
MODEL_DIR=
RUN_POSE_ON_UPLOAD=true
RUN_AI_ON_UPLOAD=false
AUTO_DISPATCH_POSE_COMMAND=true
AUTH_DATABASE_URL=postgresql+psycopg://artifact:artifact123@127.0.0.1:5432/artifact_auth

MQTT_HOST=127.0.0.1
MQTT_PORT=1883
MQTT_KEEPALIVE_SEC=60
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_QOS=1
MQTT_CMD_TOPIC_TEMPLATE=cmd/{device_id}
MQTT_ACK_TOPIC_TEMPLATE=ack/{device_id}
MQTT_STATUS_TOPIC_TEMPLATE=status/{device_id}

ARTIFACT_POSE_ROOT=
ARTIFACT_CAMERA_PARAMS_DIR=
ARTIFACT_CAMERA_PARAMS=
ARTIFACT_LENS_POSITION=1.5
ARTIFACT_GOLDEN_POSE=

ACK_HISTORY_LIMIT=200
MAX_ALIGNMENT_ITERATIONS=20
ALIGNMENT_TIMEOUT_SEC=300

# ============================================================
# SIGN MULTIPLIERS - Chieu di chuyen phan cung
# ============================================================
# Gia tri: 1 = giu nguyen deviation, -1 = dao nguyen (correction)
#
# C++ deviation tra ve delta_x, delta_z, delta_pan, delta_tilt
# la DO LECH so voi golden pose. De SUA LAI lech, ta can
# di nguoc chieu → thuong SIGN = -1.
#
# Nhung neu encoder/chiều motor nguoc voi convention cua C++,
# thi can dat SIGN = 1 (khong dao).
#
# Cach kiem tra thuc te:
#   1. Dat artifact lech sang TRAI so voi golden
#   2. Server tra delta_x > 0 (lech phai trong camera frame)
#   3. Neu slider DICH PHAI (sai) → doi SIGN_MOVE_X tu -1 sang 1
#   4. Neu slider DICH TRAI (dung) → giu -1
#
# Tuong tu cho Z (truoc/sau), PAN (xoay ngang), TILT (xoay doc)
#
# Hien tai (docker): SIGN_MOVE_X=1, SIGN_MOVE_Z=1,
#                    SIGN_ROTATE_PAN=-1, SIGN_ROTATE_TILT=-1
SIGN_MOVE_X=1
SIGN_MOVE_Z=1
SIGN_ROTATE_PAN=-1
SIGN_ROTATE_TILT=-1
