# Docker runtime variables for server/docker-compose.yml

POSTGRES_DB=artifact_auth
POSTGRES_USER=artifact
POSTGRES_PASSWORD=artifact123

APP_NAME=IoT Artifact Server
APP_VERSION=1.0.0
CORS_ALLOW_ORIGINS=*
RUN_POSE_ON_UPLOAD=true
RUN_AI_ON_UPLOAD=false
AUTO_DISPATCH_POSE_COMMAND=true

# AI detection after successful alignment
RUN_AI_ON_ALIGNED_IMAGE=true
DEFAULT_AI_MODEL_NAME=default
# DEFAULT_AI_MODEL_PATH=  # leave blank to auto-scan model_dir for first *.pt

# PostgreSQL DSN used by SQLAlchemy in server container
AUTH_DATABASE_URL=postgresql+psycopg://artifact:artifact123@postgres:5432/artifact_auth

# Local MQTT broker container
MQTT_HOST=mosquitto
MQTT_PORT=1883
MQTT_KEEPALIVE_SEC=60
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_QOS=1
MQTT_CMD_TOPIC_TEMPLATE=cmd/{device_id}
MQTT_ACK_TOPIC_TEMPLATE=ack/{device_id}
MQTT_STATUS_TOPIC_TEMPLATE=status/{device_id}

# Auth bootstrap in container startup command
ADMIN_USERNAME=admin
ADMIN_PASSWORD=123456
AUTH_SECRET_KEY=CHANGE_ME_AUTH_SECRET
AUTH_ALGORITHM=HS256
AUTH_ACCESS_TOKEN_EXPIRE_MINUTES=60

ACK_HISTORY_LIMIT=200
ARTIFACT_LENS_POSITION=1.5
