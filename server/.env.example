APP_NAME=IoT Artifact Server
APP_VERSION=1.0.0
APP_HOST=0.0.0.0
APP_PORT=8000
CORS_ALLOW_ORIGINS=*

DATA_DIR=
MODEL_DIR=
RUN_POSE_ON_UPLOAD=true
RUN_AI_ON_UPLOAD=false
AUTO_DISPATCH_POSE_COMMAND=true
AUTO_ALIGNMENT_RETRY_ON_MISSING_DEVIATION=true
AUTO_ALIGNMENT_RETRY_MAX_ATTEMPTS=5
AUTO_ALIGNMENT_MAX_MOVE_STEPS=2500
AUTO_ALIGNMENT_MAX_MOVE_ROUNDS=3

# Auth DB: de trong thi fallback sqlite:///<server>/data/auth.db
# Vi du PostgreSQL local:
# AUTH_DATABASE_URL=postgresql+psycopg://artifact:artifact123@127.0.0.1:5432/artifact_auth
AUTH_DATABASE_URL=

MQTT_HOST=100.111.111.100
MQTT_PORT=1883
MQTT_KEEPALIVE_SEC=60
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_QOS=1
MQTT_CMD_TOPIC_TEMPLATE=cmd/{device_id}
MQTT_ACK_TOPIC_TEMPLATE=ack/{device_id}
MQTT_STATUS_TOPIC_TEMPLATE=status/{device_id}

ARTIFACT_POSE_ROOT=
ARTIFACT_CAMERA_PARAMS_DIR=
ARTIFACT_CAMERA_PARAMS=
ARTIFACT_LENS_POSITION=
ARTIFACT_GOLDEN_POSE=

ACK_HISTORY_LIMIT=200
